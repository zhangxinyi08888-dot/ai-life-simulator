# VITE_DEEPSEEK_API_KEY: Required by the GitHub Pages browser build.
# This value is embedded into public frontend assets at build time.
VITE_DEEPSEEK_API_KEY="MY_DEEPSEEK_API_KEY"

# Optional browser AI settings.
VITE_DEEPSEEK_MODEL="deepseek-v4-flash"
VITE_DEEPSEEK_BASE_URL="https://api.deepseek.com"

# Optional legacy local server settings. Not used by the GitHub Pages build.
DEEPSEEK_API_KEY="MY_DEEPSEEK_API_KEY"
DEEPSEEK_MODEL="deepseek-v4-flash"
DEEPSEEK_BASE_URL="https://api.deepseek.com"
