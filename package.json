{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "analyze:financial-baseline": "node scripts/analyze-financial-ledger-baseline.mjs --verify",
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "server:dev": "tsx server.ts",
    "server:build": "esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "server:start": "node dist/server.cjs",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "test": "node scripts/run-typescript-tests.mjs",
    "test:financial-baseline": "node --test scripts/analyze-financial-ledger-baseline.test.mjs",
    "test:financial-m2": "node --import tsx --test src/domain/finance/reduceFinancialLedger.test.ts",
    "test:financial-m5": "node --import tsx --test src/domain/career/careerState.test.ts src/domain/finance/recurringLifecycle.test.ts src/domain/finance/debtLifecycle.test.ts src/domain/finance/businessLifecycle.test.ts src/domain/finance/financialProblemCoverage.test.ts",
    "test:financial-m7": "node --import tsx --test src/domain/finance/financialM7Gate.test.ts src/domain/finance/commitFinancialDomainTransaction.test.ts src/services/simulation/simulationService.test.ts src/utils/simulationTransaction.test.ts scripts/financial-real-browser-audit-helpers.test.mjs",
    "test:financial-m7-focused": "node --import tsx --test src/domain/finance/financialM7FocusedGate.test.ts src/domain/finance/openingFinancialFacts.test.ts src/domain/finance/financialM7Gate.test.ts src/services/simulation/financialM7FocusedSimulation.test.ts"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "html-to-image": "^1.11.13",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
